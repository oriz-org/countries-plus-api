---
import Layout from '../layouts/Layout.astro';
import all from '../../all.json';

const sample = all.find((r: any) => r.alpha2 === 'IN');
const total = all.length;
const withMotto = all.filter((r: any) => r.motto).length;
const withFormer = all.filter((r: any) => r.former_names || r.former_capitals).length;
---
<Layout path="/">
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-12">
    <p class="font-mono text-xs uppercase tracking-wider text-teal-600 dark:text-teal-400">Extended country data</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
      Countries+ <span class="text-teal-600 dark:text-teal-400">API</span>
    </h1>
    <p class="mt-5 max-w-2xl text-lg text-zinc-600 dark:text-zinc-400">
      What <a href="https://restcountries.com" target="_blank" rel="noopener noreferrer" class="underline decoration-teal-500/40 underline-offset-4 hover:text-teal-700 dark:hover:text-teal-400">RestCountries</a> doesn't have.
      Mottos &amp; translations, anthem titles, founding dates, former capitals, former names &mdash; for
      <strong class="font-semibold text-zinc-900 dark:text-zinc-100">{total}</strong> countries.
      Free, static, no auth.
    </p>

    <div class="mt-6 rounded-md border border-teal-200 bg-teal-50 p-4 text-sm text-teal-900 dark:border-teal-800 dark:bg-teal-950/40 dark:text-teal-200">
      <strong class="font-semibold">Heads-up:</strong> this is a <em>supplement</em> to <a href="https://restcountries.com" target="_blank" rel="noopener noreferrer" class="underline">RestCountries</a>, not a replacement. RestCountries already has population, flags, languages, capitals (current), borders, etc. This API only carries the fields it doesn't &mdash; cross-link by <code class="font-mono">alpha2</code>/<code class="font-mono">alpha3</code>/<code class="font-mono">numeric</code>.
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/docs" class="rounded-md bg-teal-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-teal-700">Read the docs</a>
      <a href="/explorer" class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-700 transition-colors hover:border-teal-500 hover:text-teal-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-teal-500 dark:hover:text-teal-400">Try the explorer</a>
      <a href="https://github.com/oriz-org/countries-plus-api" target="_blank" rel="noopener noreferrer" class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-700 transition-colors hover:border-zinc-500 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500">Source on GitHub</a>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Try it</h2>
    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <div>
        <p class="mb-2 text-sm text-zinc-600 dark:text-zinc-400">Request:</p>
        <pre class="overflow-x-auto rounded-md border border-zinc-200 bg-zinc-50 p-4 text-sm dark:border-zinc-800 dark:bg-zinc-900"><code class="font-mono text-zinc-800 dark:text-zinc-200">curl https://countries-plus.oriz.in/countries/IN.json</code></pre>
      </div>
      <div>
        <p class="mb-2 text-sm text-zinc-600 dark:text-zinc-400">Response:</p>
        <pre class="overflow-x-auto rounded-md border border-zinc-200 bg-zinc-50 p-4 text-xs dark:border-zinc-800 dark:bg-zinc-900"><code class="font-mono text-zinc-800 dark:text-zinc-200">{JSON.stringify(sample, null, 2)}</code></pre>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">How to use</h2>
    <div class="mt-4 grid gap-6 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
        <h3 class="font-mono text-sm font-semibold text-teal-700 dark:text-teal-400">via countries-plus.oriz.in</h3>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Cloudflare Pages, custom domain, free TLS. Recommended for browser apps.</p>
        <pre class="mt-3 overflow-x-auto rounded bg-zinc-50 p-3 text-xs dark:bg-zinc-900"><code class="font-mono">https://countries-plus.oriz.in/countries/IN.json</code></pre>
      </div>
      <div class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
        <h3 class="font-mono text-sm font-semibold text-teal-700 dark:text-teal-400">via jsDelivr</h3>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Pinned to a git ref. Recommended for reproducible builds.</p>
        <pre class="mt-3 overflow-x-auto rounded bg-zinc-50 p-3 text-xs dark:bg-zinc-900"><code class="font-mono">https://cdn.jsdelivr.net/gh/oriz-org/countries-plus-api@main/countries/IN.json</code></pre>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Stats</h2>
    <dl class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-5">
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Countries</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">{total}</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">With motto</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">{withMotto}</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">With history</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">{withFormer}</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Data license</dt>
        <dd class="mt-1 font-mono text-lg font-semibold">CC BY-SA</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Cost</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">&#8377;0/mo</dd>
      </div>
    </dl>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Why use this</h2>
    <ul class="mt-4 space-y-2 text-zinc-700 dark:text-zinc-300">
      <li class="flex gap-3"><span class="text-teal-600 dark:text-teal-400">&middot;</span> Pairs with RestCountries: same ISO codes, complementary fields, no overlap.</li>
      <li class="flex gap-3"><span class="text-teal-600 dark:text-teal-400">&middot;</span> Static JSON files &mdash; no API key, no rate limit, no quota.</li>
      <li class="flex gap-3"><span class="text-teal-600 dark:text-teal-400">&middot;</span> Served from Cloudflare Pages and jsDelivr edge caches.</li>
      <li class="flex gap-3"><span class="text-teal-600 dark:text-teal-400">&middot;</span> Open data &mdash; Wikidata + Wikipedia infoboxes, fork it, audit it, PR a fix.</li>
    </ul>
  </section>
</Layout>
